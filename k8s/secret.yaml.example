# Copy this to secret.yaml, fill in real values, and apply it manually
# (kubectl apply -f k8s/secret.yaml) BEFORE the first deployment — it is
# intentionally NOT committed to git and NOT applied by the CI pipeline.
#
# Get mongo-uri from MongoDB Atlas.
# Get redis-addr from `terraform output redis_endpoint` in starttech-infra,
# formatted as "<endpoint>:6379".
# Get allowed-origins from `terraform output cloudfront_domain_name`,
# formatted as "https://<that-domain>".
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
type: Opaque
stringData:
  mongo-uri: "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/much_todo_db"
  jwt-secret-key: "replace-with-a-long-random-string"
  redis-addr: "<elasticache-endpoint>:6379"
  allowed-origins: "https://<your-cloudfront-domain>.cloudfront.net"
